generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VENDOR
  CUSTOMER
  AFFILIATE
}

enum VendorStatus {
  PENDING_VERIFICATION
  APPROVED
  SUSPENDED
  REJECTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  INACTIVE
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BLOCKED
  OFFLINE_BOOKING
}

enum CartItemType {
  SERVICE
  PACKAGE
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_RECEIVED
  VENDOR_REVIEW
  VENDOR_ACCEPTED
  CUSTOMER_CONFIRMATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYTABS
  CHECKOUT_COM
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentType {
  ADVANCE
  REMAINING
  FULL
}

enum CouponType {
  FLAT
  PERCENTAGE
}

enum ReviewStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum SettlementStatus {
  PENDING_PAYOUT
  PAID
  ON_HOLD
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor       Vendor?
  carts        Cart[]
  bookings     Booking[]
  reviews      Review[]

  @@map("users")
}

model Vendor {
  id                 String       @id @default(cuid())
  userId             String?      @unique
  companyName        String
  contactPerson      String
  email              String       @unique
  phone              String
  tradeLicenseNumber String
  vatNumber          String?
  status             VendorStatus @default(PENDING_VERIFICATION)
  cities             String[]
  capacityPerDay     Int          @default(1)
  commissionPercent  Decimal      @db.Decimal(5, 2)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user               User?        @relation(fields: [userId], references: [id])
  documents          VendorDocument[]
  services           VendorService[]
  packages           EventPackage[]
  availability       VendorAvailability[]
  settlements        Settlement[]

  @@map("vendors")
}

model VendorDocument {
  id        String   @id @default(cuid())
  vendorId  String
  type      String
  fileKey   String
  fileUrl   String?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  vendor    Vendor   @relation(fields: [vendorId], references: [id])

  @@map("vendor_documents")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  services  VendorService[]

  @@map("categories")
}

model VendorService {
  id          String        @id @default(cuid())
  vendorId    String
  categoryId  String
  title       String
  description String
  city        String
  amount      Int
  maxAmount   Int?
  currency    String        @default("AED")
  priceUnit   String        @default("per event")
  imageUrl    String?
  tags        String[]
  gallery     String[]
  features    String[]
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor      Vendor        @relation(fields: [vendorId], references: [id])
  category    Category      @relation(fields: [categoryId], references: [id])
  subServices VendorSubService[]
  packageItems PackageItem[]

  @@unique([vendorId, title])
  @@index([categoryId, city, status])
  @@map("vendor_services")
}

model VendorSubService {
  id          String        @id @default(cuid())
  serviceId   String
  title       String
  description String
  amount      Int
  currency    String        @default("AED")
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  service     VendorService @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, title])
  @@index([serviceId, status])
  @@map("vendor_sub_services")
}

model EventPackage {
  id          String        @id @default(cuid())
  vendorId    String
  title       String
  description String
  amount      Int
  currency    String        @default("AED")
  priceUnit   String        @default("package")
  inclusions  String[]
  features    String[]
  maxGuests   Int?
  durationHours Int?
  isPopular   Boolean       @default(false)
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor      Vendor        @relation(fields: [vendorId], references: [id])
  items       PackageItem[]

  @@unique([vendorId, title])
  @@map("event_packages")
}

model PackageItem {
  id        String @id @default(cuid())
  packageId String
  serviceId String

  package   EventPackage  @relation(fields: [packageId], references: [id])
  service   VendorService @relation(fields: [serviceId], references: [id])

  @@unique([packageId, serviceId])
  @@map("package_items")
}

model VendorAvailability {
  id          String             @id @default(cuid())
  vendorId    String
  date        DateTime           @db.Date
  status      AvailabilityStatus
  capacity    Int                @default(1)
  bookedCount Int                @default(0)
  note        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  vendor      Vendor             @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, date])
  @@map("vendor_availability")
}

model Cart {
  id         String     @id @default(cuid())
  customerId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer   User       @relation(fields: [customerId], references: [id])
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id        String       @id @default(cuid())
  cartId    String
  type      CartItemType
  itemId    String
  eventDate DateTime     @db.Date
  quantity  Int          @default(1)

  cart      Cart         @relation(fields: [cartId], references: [id])

  @@map("cart_items")
}

model Booking {
  id                  String        @id @default(cuid())
  customerId          String
  status              BookingStatus @default(PENDING_PAYMENT)
  eventAddress        String
  notes               String?
  couponCode          String?
  subtotalAmount      Int
  discountAmount      Int           @default(0)
  totalAmount         Int
  advanceDueAmount    Int
  remainingDueAmount  Int
  currency            String        @default("AED")
  vendorAcceptedAt    DateTime?
  customerConfirmedAt DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancelReason        String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  customer            User          @relation(fields: [customerId], references: [id])
  items               BookingItem[]
  payments            Payment[]
  refunds             Refund[]
  reviews             Review[]
  settlements         Settlement[]

  @@index([customerId, status])
  @@map("bookings")
}

model BookingItem {
  id         String       @id @default(cuid())
  bookingId  String
  vendorId   String
  type       CartItemType
  itemId     String
  title      String
  eventDate  DateTime     @db.Date
  quantity   Int
  unitAmount Int
  currency   String       @default("AED")

  booking    Booking      @relation(fields: [bookingId], references: [id])

  @@index([vendorId, eventDate])
  @@map("booking_items")
}

model Payment {
  id             String          @id @default(cuid())
  bookingId      String
  provider       PaymentProvider @default(STRIPE)
  providerRef    String?
  paymentType    PaymentType
  amount         Int
  currency       String          @default("AED")
  status         PaymentStatus   @default(REQUIRES_PAYMENT_METHOD)
  clientSecret   String?
  succeededAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  booking        Booking         @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Refund {
  id            String   @id @default(cuid())
  bookingId     String
  paymentId     String?
  amount        Int
  currency      String   @default("AED")
  refundPercent Int
  reason        String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id])

  @@map("refunds")
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  type              CouponType
  value             Int
  maxDiscountAmount Int?
  currency          String     @default("AED")
  minOrderAmount    Int        @default(0)
  active            Boolean    @default(true)
  expiresAt         DateTime?
  createdAt         DateTime   @default(now())

  @@map("coupons")
}

model Review {
  id        String       @id @default(cuid())
  bookingId String
  vendorId  String
  customerId String
  rating    Int
  comment   String
  status    ReviewStatus @default(PENDING_APPROVAL)
  createdAt DateTime     @default(now())
  approvedAt DateTime?

  booking   Booking      @relation(fields: [bookingId], references: [id])
  customer  User         @relation(fields: [customerId], references: [id])

  @@unique([bookingId, customerId])
  @@map("reviews")
}

model Settlement {
  id               String           @id @default(cuid())
  bookingId        String
  vendorId         String
  grossAmount      Int
  commissionAmount Int
  payableAmount    Int
  currency         String           @default("AED")
  status           SettlementStatus @default(PENDING_PAYOUT)
  createdAt        DateTime         @default(now())
  paidAt           DateTime?

  booking          Booking          @relation(fields: [bookingId], references: [id])
  vendor           Vendor           @relation(fields: [vendorId], references: [id])

  @@map("settlements")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  channel   String
  event     String
  recipient String
  payload   Json
  status    String   @default("PENDING")
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@map("notifications")
}
