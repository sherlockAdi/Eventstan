PORT=4000
API_PREFIX=api/v1
API_PUBLIC_URL=https://api.eventstan.com/api/v1
SWAGGER_PATH=docs
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN_SECONDS=86400
CORS_ORIGINS=https://eventstan.com,https://admin.eventstan.com,https://vendor.eventstan.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/eventstan_db?schema=public
ALLOW_BOOTSTRAP=false
MINIO_ENDPOINT=minioapis.neuralinfo.co.in
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=eventstan
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=https://minioapis.neuralinfo.co.in/eventstan
